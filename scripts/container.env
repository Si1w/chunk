# Container configuration — sourced by SLURM scripts.
#
# Provides uv_run() to execute commands inside the Singularity container.
# Usage:
#   source "$(dirname "$0")/container.env"
#   uv_run python -m my_module --flag value

SIF="/scratch/users/${USER}/images/pytorch_24.12.sif"
UV_BIN="$(which uv)"

uv_run() {
    singularity exec --nv \
        -B "/users/${USER},/scratch/users/${USER}" \
        --cwd "$(pwd)" \
        "${SIF}" "${UV_BIN}" run "$@"
}
